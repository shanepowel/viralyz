# Viralyz environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------
# Postgres connection string. Works with Neon out of the box (this app uses the
# standard node-postgres driver). Example Neon value:
# postgres://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Long random string used to sign session cookies (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# development | production
NODE_ENV=development

# Port the server listens on. Defaults to 5000.
PORT=5000

# Public base URL of the app, used for OAuth callbacks and email links.
APP_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# AI (required for content generation, digests, signal correlation)
# ---------------------------------------------------------------------------
# On Replit these are provided by the OpenAI AI integration. Off Replit, point
# them at OpenAI directly:
#   AI_INTEGRATIONS_OPENAI_API_KEY = your OpenAI API key (sk-...)
#   AI_INTEGRATIONS_OPENAI_BASE_URL = https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# Authentication (Replit Auth / OIDC) - REPLIT SPECIFIC
# ---------------------------------------------------------------------------
# The app ships with Replit Auth (OpenID Connect). Off Replit you must replace
# this with your own OIDC provider (Auth0, Clerk, Cognito, etc.). See HANDOFF.md.
ISSUER_URL=https://replit.com/oidc
REPL_ID=

# ---------------------------------------------------------------------------
# Object storage - REPLIT SPECIFIC
# ---------------------------------------------------------------------------
# Used for uploaded media (thumbnails, brand assets). Off Replit, swap the
# @replit/object-storage usage for S3/R2/GCS. See HANDOFF.md.
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ---------------------------------------------------------------------------
# Email (weekly competitor digests)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
EMAIL_FROM=digests@yourdomain.com

# ---------------------------------------------------------------------------
# Autopilot (autonomous posting agent)
# ---------------------------------------------------------------------------
# Symmetric key used to encrypt stored platform OAuth tokens at rest.
# Generate with `openssl rand -hex 32`.
AUTOPILOT_TOKEN_KEY=
# Comma separated user IDs allowed to trigger the agent tick manually.
AUTOPILOT_TICK_ADMINS=

# ---------------------------------------------------------------------------
# Social platform OAuth apps (only needed for the platforms you enable)
# ---------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=

THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Payments (PayPal subscriptions)
# ---------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
