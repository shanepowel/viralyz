# Viralyz monorepo environment
# Copy to `.env` in apps/app (and optionally apps/web)

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------
# Neon (recommended): use the pooled connection string from the Neon dashboard
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/viralyz?sslmode=disable
SESSION_SECRET=change-me-to-a-long-random-string
# Do not set NODE_ENV here. Next.js / Node set it per command.
# NODE_ENV=development in .env breaks Next 16 prerender (/_global-error useContext).
PORT=5000
APP_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# Auth — local / Cursor (default)
# With AUTH_MODE=dev (or when REPL_ID is unset), Sign in creates a local demo user
# and skips Replit OIDC. Visit http://localhost:5000 then click Sign in.
# ---------------------------------------------------------------------------
AUTH_MODE=dev

# Replit Auth (only when AUTH_MODE is not "dev" AND REPL_ID is set)
# ISSUER_URL=https://replit.com/oidc
# REPL_ID=

# ---------------------------------------------------------------------------
# AI (required for creator tools)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# Legacy Replit AI integration aliases (optional)
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Storage — local uploads (default when PRIVATE_OBJECT_DIR unset)
# ---------------------------------------------------------------------------
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=./uploads

# Cloud object storage (production)
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=

# ---------------------------------------------------------------------------
# Email, payments, social OAuth (optional)
# ---------------------------------------------------------------------------
# SENDGRID_API_KEY=
# EMAIL_FROM=digests@yourdomain.com
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Inngest (optional — local job runner works without these)
# ---------------------------------------------------------------------------
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_DEV=1

# ---------------------------------------------------------------------------
# Next.js marketing site
# ---------------------------------------------------------------------------
# Next.js marketing site — leave unset on Vercel so CTAs use /dashboard.
# Only set this to a non-localhost public URL once the Express app is hosted.
# NEXT_PUBLIC_APP_URL=https://app.viralyz.com
NEXT_PUBLIC_APP_URL=
